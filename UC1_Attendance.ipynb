   "source": [
    "# UC1 - Attendance\n",
    "This simulates employee presence using random module."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "dee1a1d9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Employee is Present\n"
     ]
    }
   ],
   "source": [
    "import random\n",
    "\n",
    "IS_PRESENT = 1\n",
    "\n",
    "emp_check = random.randint(0, 1)\n",
    "\n",
    "if emp_check == IS_PRESENT:\n",
    "    print(\"Employee is Present\")\n",
    "else:\n",
    "    print(\"Employee is Absent\")"
   ]
  },
